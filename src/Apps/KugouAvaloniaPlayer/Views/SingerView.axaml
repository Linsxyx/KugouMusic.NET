<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KugouAvaloniaPlayer.ViewModels"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:localControls="using:KugouAvaloniaPlayer.Controls"
             xmlns:behaviors="using:KugouAvaloniaPlayer.Behaviors"
             xmlns:controls="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             x:Class="KugouAvaloniaPlayer.Views.SingerView"
             x:DataType="vm:SingerViewModel">
    <UserControl.Styles>
        <Style Selector="Button.SortToggleButton">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="MinWidth" Value="94" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="#2E000000" />
            <Setter Property="BorderBrush" Value="#38FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.SortToggleButton:pointerover">
            <Setter Property="Background" Value="#48000000" />
        </Style>
        <Style Selector="Button.SortToggleButton TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Styles>

    <suki:GlassCard Margin="15" Padding="20">
        <localControls:SongCollectionDetailView
            Cover="{Binding SingerAvatar}"
            Title="{Binding SingerName}"
            Songs="{Binding Songs}"
            LoadMoreCommand="{Binding LoadMoreCommand}"
            BackCommand="{Binding $parent[suki:SukiWindow].((vm:MainWindowViewModel)DataContext).NavigateBackCommand}"
            IsLoading="{Binding IsLoading}"
            IsLoadingMore="{Binding IsLoadingMore}"
            LoadingText="正在加载..."
            LoadingMoreText="正在加载更多..."
            ListPadding="0,0,0,50"
            TitleFontSize="24">
            <localControls:SongCollectionDetailView.Actions>
                <Button Command="{Binding ToggleSortCommand}"
                        Classes="SortToggleButton"
                        Cursor="Hand"
                        Margin="500,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Svg Path="/Assets/FormatList.svg" Width="16" Height="16" />
                        <TextBlock Text="{Binding CurrentSortText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </localControls:SongCollectionDetailView.Actions>
        </localControls:SongCollectionDetailView>
    </suki:GlassCard>
</UserControl>
